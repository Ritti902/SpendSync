APP_ENV=development
PORT=8080

MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=expensemania

JWT_SECRET=spendsync-dev-secret
JWT_ACCESS_SECRET=spendsync-dev-access-secret
JWT_REFRESH_SECRET=spendsync-dev-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h

FRONTEND_URL=http://localhost:5173
COOKIE_SECURE=false
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW=1m

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@spendsync.local
REDIS_URL=redis://localhost:6379

DEFAULT_CURRENCY=INR
DEFAULT_TIMEZONE=Asia/Kolkata
